@page "/disasterCards"
@using ThunderbirdsBoardGameEngine.Catalog.Contracts.Dtos.V1
@using ThunderbirdsBoardGameEngine.Rules.Contracts.Dtos.Rescue.CalculateRescueTarget.V1
@using ThunderbirdsBoardGameEngine.UI.Interfaces
@inject ICharactersService CharactersService
@inject IDisasterCardService DisasterCardService
@inject IRescueService RescueService

<h3>Select a Disaster Card</h3>

@if (cards is null)
{
    <p data-testid="loading">Loading cards...</p>
}
else if (cards.Count == 0)
{
    <p data-testid="empty-state">No disaster cards available.</p>
}
else
{
    <label for="disasterSelect" class="form-label">Card</label>
    <select id="disasterSelect"
            class="form-select"
            @bind-Value="SelectedCardId"
            @bind-Value:event="onchange">
        <option value="">-- Select a card --</option>
        @foreach (var c in cards)
        {
            <option value="@c.Id">@c.Name</option>  @* users see title; value is ID *@
        }
    </select>

    @if (selectedCard is not null)
    {
        <div class="mt-4" data-testid="details">
            <h3>Disaster Card Details</h3>
            <div class="card shadow-sm p-3">
                <h4>@selectedCard.Name</h4>
                <p><strong>Difficulty:</strong> @selectedCard.DifficultyNumber</p>
                <p><strong>Location:</strong> @selectedCard.Location</p>
                <p><strong>Rescue Type:</strong> @selectedCard.RescueType</p>

                @if (selectedCard.BonusConditions?.Any() == true)
                {
                    <h5>Bonus Conditions</h5>

                    <ul class="list-unstyled">
                        @foreach (var bonus in selectedCard.BonusConditions)
                        {
                            var checkboxId = $"bonus-{bonus.Key}";

                            <li>
                                <div class="form-check">
                                    <input class="form-check-input"
                                           type="checkbox"
                                           id="@checkboxId"
                                           data-testid="bonus-checkbox"
                                           data-bonus-key="@bonus.Key"
                                           checked="@selectedBonusKeys.Contains(bonus.Key)"
                                           @onchange="e => OnBonusToggled(bonus.Key, e)" />

                                    <label class="form-check-label" for="@checkboxId">
                                        @bonus.Description
                                    </label>
                                </div>
                            </li>
                        }
                    </ul>
                }

                @if (selectedCard.Rewards?.Any() == true)
                {
                    <h5>Rewards</h5>
                    <ul>
                        @foreach (var reward in selectedCard.Rewards)
                        {
                            <li>@reward.DisplayName</li>
                        }
                    </ul>
                }

                @if (characters is not null && characters.Count > 0)
                {
                    <label for="characterSelect" class="form-label">Character</label>
                    <select id="characterSelect" class="form-select"
                            @key="selectedCharacterCode"
                            @bind-Value="selectedCharacterCode"
                            @bind-Value:event="onchange" required>
                        <option value="">-- Select a character --</option>

                        @foreach (var c in characters)
                        {
                            <option value="@c.Key">@c.DisplayName</option> @* users see display; value is key *@ 
                                }
                    </select>
                }

                <button class="btn btn-primary mt-3"
                        data-testid="calculate-button"
                        disabled="@IsCalculateDisabled"
                        @onclick="CalculateRescueTarget">
                    Calculate Rescue Target
                </button>


                @if (calculationResult is not null)
                {
                    <div class="alert alert-info mt-3"
                         data-testid="rescue-calculation-result">
                        <p><strong>Target Number:</strong> @calculationResult.TargetNumber</p>
                        <p><strong>Total Bonus:</strong> @calculationResult.TotalBonus</p>
                    </div>
                }

                @if (calculationFailed)
                {
                    <div class="alert alert-danger mt-3"
                        data-testid="rescue-calculation-error">
                        Unable to calculate rescue target.
                    </div>
                }
            </div>
        </div>
    }
}

@code {
    private IReadOnlyList<DisasterCardDto>? cards;
    private IReadOnlyDictionary<int, DisasterCardDto>? cardsDictionary;
    private IReadOnlyList<CharacterDto>? characters;

    private int? selectedCardId;
    private DisasterCardDto? selectedCard;
    private string? selectedCharacterCode;

    private readonly HashSet<string> selectedBonusKeys = new();

    private CalculateRescueTargetResponseDto? calculationResult;
    private bool calculationFailed;
    private bool isCalculating;

    private bool IsCalculateDisabled =>
        isCalculating
        || selectedCard is null
        || string.IsNullOrWhiteSpace(selectedCharacterCode);


    protected override async Task OnInitializedAsync()
    {
        // Load once (disaster cards only)
        var all = await DisasterCardService.GetAllAsync();

        cards = all.OrderBy(c => c.Name ?? string.Empty, StringComparer.OrdinalIgnoreCase).ToList();

        // Build an ID -> DTO index (handles duplicates by keeping the first)
        var dict = new Dictionary<int, DisasterCardDto>(cards.Count);
        foreach (var c in cards)
            dict.TryAdd(c.Id, c);

        cardsDictionary = dict;

        characters = await CharactersService.GetAllAsync();
    }

    private int? SelectedCardId
    {
        get => selectedCardId;
        set
        {
            if (selectedCardId == value)
            {
                return;
            }

            selectedCardId = value;

            selectedBonusKeys.Clear();
            calculationResult = null;
            selectedCharacterCode = null;

            selectedCard = (value is int id && cardsDictionary?.TryGetValue(id, out var card) == true)
                ? card
                : null;
        }
    }

    private void OnBonusToggled(string key, ChangeEventArgs e)
    {
        var isChecked = (bool)e.Value!;

        if (isChecked)
        {
            selectedBonusKeys.Add(key);
        }
        else
        {
            selectedBonusKeys.Remove(key);
        }
    }

    private async Task CalculateRescueTarget()
    {
        if (selectedCard is null)
        {
            return;
        }

        if (string.IsNullOrWhiteSpace(selectedCharacterCode))
        {
            return;
        }

        isCalculating = true;
        calculationFailed = false;
        calculationResult = null;

        try
        {
            calculationResult =
                await RescueService.CalculateRescueTargetAsync(
                    selectedCard.Code,
                    selectedBonusKeys,
                    selectedCharacterCode);

            calculationFailed = calculationResult is null;
        }
        finally
        {
            isCalculating = false;
        }
    }
}
