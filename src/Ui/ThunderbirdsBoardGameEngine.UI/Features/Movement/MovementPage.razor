@page "/movement"
@using ThunderbirdsBoardGameEngine.UI.Features.Movement.Components

<h3>Movement</h3>

<ThunderbirdSelector 
    Thunderbirds="_mobileThunderbirds"
    @bind-SelectedThunderbirdCode="_thunderbirdCode" />

@if (!string.IsNullOrEmpty(_thunderbirdCode))
{
    <label for="startLocation" class="form-label">Start Location</label>
    <LocationSelector Id="startLocation"
                      Locations="_movementLocations"
                      @bind-SelectedLocationKey="_startLocationCode" />

    <label for="destination" class="form-label">Destination</label>
    <LocationSelector Id="destination"
                      Locations="_movementLocations"
                      @bind-SelectedLocationKey="_destinationCode" />

    <button class="btn btn-primary mt-3"
            data-testid="calculate-button"
            disabled="@IsValidationDisabled"
            @onclick="ValidateMovement">
        Validate Movement
    </button>

    @if (_validationResult is not null)
    {
        <MovementResultDetail MovementResult="_validationResult" />
    }

    @if (_validationFailed)
    {
        <div class="alert alert-danger mt-3"
             data-testid="validation-failed">            
            <p>There was an error validating the movement. Please check the inputs and try again.</p>
        </div>
    }
}