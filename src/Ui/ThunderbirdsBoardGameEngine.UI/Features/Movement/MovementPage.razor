@page "/movement"

<h3>Movement</h3>

<label for="movementSelect" class="form-label">Thunderbird</label>
<select id="movementSelect"
        class="form-select"
        @bind-Value="_thunderbirdCode"
        @bind-Value:event="onchange">
    <option value="">-- Select a Thunderbird --</option>
    @foreach (var t in _mobileThunderbirds)
    {
        <option value="@t.Key">@t.DisplayName</option>
    }
</select>

@if (!string.IsNullOrEmpty(_thunderbirdCode))
{
    <label for="startLocation" class="form-label">Start Location</label>
    <select id="startLocation"
            class="form-select"
            @bind-Value="_startLocationCode"
            @bind-Value:event="onchange">
        <option value="">-- Select a Start Location --</option>
        @foreach (var l in _movementLocations)
        {
            <option value="@l.Key">@l.DisplayName</option>
        }
    </select>

    <label for="destination" class="form-label">Destination</label>
    <select id="destination"
            class="form-select"
            @bind-Value="_destinationCode"
            @bind-Value:event="onchange">
        <option value="">-- Select a Destination --</option>
        @foreach (var l in _movementLocations)
        {
            <option value="@l.Key">@l.DisplayName</option>
        }
    </select>

    <button class="btn btn-primary mt-3"
            data-testid="calculate-button"
            disabled="@IsValidationDisabled"
            @onclick="ValidateMovement">
        Validate Movement
    </button>
}