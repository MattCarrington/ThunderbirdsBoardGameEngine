        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4">
            <a href="https://learn.microsoft.com/aspnet/core/" target="_blank">About</a>
        </div>

        <article class="content px-4">
            @Body
        </article>
        <footer class="border-top mt-4 py-2 text-muted small text-center">
            Thunderbirds Board Game Engine UI @($"v{UiVersionInfo.UiVersion}")
        </footer>
    </main>
</div>
