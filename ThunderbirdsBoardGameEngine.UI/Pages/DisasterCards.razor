@page "/disasterCards"
@using ThunderbirdsBoardGameEngine.Catalog.Contracts.Dtos.V1
@using ThunderbirdsBoardGameEngine.UI.Interfaces
@inject IDisasterCardService DisasterCardService

<h3>Select a Disaster Card</h3>

@if (cards is null)
{
    <p>Loading cards...</p>
}
else if (cards.Count == 0)
{
    <p>No disaster cards available.</p>
}
else
{
    <label for="disasterSelect" class="form-label">Card</label>
    <select id="disasterSelect"
            class="form-select"
            @bind-Value="SelectedCardId"
            @bind-Value:event="onchange">
        <option value="">-- Select a card --</option>
        @foreach (var c in cards)
        {
            <option value="@c.Id">@c.Name</option>  @* users see title; value is ID *@
        }
    </select>

    @if (selectedCard is not null)
    {
        <div class="mt-4">
            <h3>Disaster Card Details</h3>
            <div class="card shadow-sm p-3">
                <h4>@selectedCard.Name</h4>
                <p><strong>Difficulty:</strong> @selectedCard.DifficultyNumber</p>
                <p><strong>Location:</strong> @selectedCard.Location</p>
                <p><strong>Rescue Type:</strong> @selectedCard.RescueType</p>

                @if (selectedCard.BonusConditions?.Any() == true)
                {
                    <h5>Bonus Conditions</h5>
                    <ul>
                        @foreach (var bonus in selectedCard.BonusConditions)
                        {
                            <li>@bonus.Description</li>
                        }
                    </ul>
                }

                @if (selectedCard.Rewards?.Any() == true)
                {
                    <h5>Rewards</h5>
                    <ul>
                        @foreach (var reward in selectedCard.Rewards)
                        {
                            <li>@reward.DisplayName</li>
                        }
                    </ul>
                }
            </div>
        </div>
    }
}

@code {
    private IReadOnlyList<DisasterCardDto>? cards;
    private IReadOnlyDictionary<int, DisasterCardDto>? cardsDictionary;

    private int? selectedCardId;
    private DisasterCardDto? selectedCard;

    protected override async Task OnInitializedAsync()
    {
        // Load once (disaster cards only)
        var all = await DisasterCardService.GetAllAsync();

        cards = all.OrderBy(c => c.Name ?? string.Empty, StringComparer.OrdinalIgnoreCase).ToList();

        // Build an ID -> DTO index (handles duplicates by keeping the first)
        var dict = new Dictionary<int, DisasterCardDto>(cards.Count);
        foreach (var c in cards)
            dict.TryAdd(c.Id, c);

        cardsDictionary = dict;
    }

    private int? SelectedCardId
    {
        get => selectedCardId;
        set
        {
            selectedCardId = value;
            selectedCard = (value is int id && cardsDictionary?.TryGetValue(id, out var c) == true) ? c : null;
        }
    }
}
