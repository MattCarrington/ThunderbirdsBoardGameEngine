@page "/disaster/{Id:int}"
@using ThunderbirdsBoardGameEngine.GameData.Api.Messages.Dtos.V1
@using ThunderbirdsBoardGameEngine.UI.Interfaces
@inject IDisasterCardService DisasterCardService

<h3>Disaster Card Details</h3>

@if (card == null)
{
    <p>Loading card...</p>
}
else
{
    <div class="card shadow-sm p-3">
        <h4>@card.Name</h4>
        <p><strong>Difficulty:</strong> @card.DifficultyNumber</p>
        <p><strong>Location:</strong> @card.Location</p>
        <p><strong>Rescue Type:</strong> @card.RescueType</p>

        @if (card.BonusConditions?.Any() == true)
        {
            <h5>Bonus Conditions</h5>
            <ul>
                @foreach (var bonus in card.BonusConditions)
                {
                    <li>@bonus.Description</li>
                }
            </ul>
        }

        @if (card.Rewards?.Any() == true)
        {
            <h5>Rewards</h5>
            <ul>
                @foreach (var reward in card.Rewards)
                {
                    <li>@reward.DisplayName</li>
                }
            </ul>
        }
    </div>
}

@code {
    [Parameter] public int Id { get; set; }
    private DisasterCardDto? card;

    protected override async Task OnInitializedAsync()
    {
        card = await DisasterCardService.GetByIdAsync(Id);
    }
}
